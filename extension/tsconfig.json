{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    // "allowImportingTsExtensions": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "typeRoots": [
      "./node_modules/@types",
      "./"  // includes declarations (global.d.ts) at the root 
    ]
  },
  "include": [
    "**/*.d.ts",    // This ensures all declaration files are included
    "entrypoints",
    "wxt.config.ts"
  ]
}